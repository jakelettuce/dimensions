# ============================================
# Dimensions .gitignore
# ============================================

# ── Dependencies ──
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases

# ── Build & Distribution ──
dist/
dist-ssr/
out/
build/
*.local
*.tsbuildinfo

# ── Electron ──
dist_electron/
release/
*.dmg
*.exe
*.AppImage
*.snap
*.deb
*.rpm
*.msi
*.blockmap
*.zip

# ── Internal Docs (not for public repo) ──
# Implementation plans, technical specs, internal notes.
# These are working documents for the dev team, not shipped docs.
docs/implementation/
docs/internal/

# ── Environment & Secrets ──
# NEVER commit credentials, tokens, or env files.
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
*.pfx
*.cer
credentials.json
serviceAccountKey.json

# ── Database ──
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing & Coverage ──
coverage/
*.lcov
.nyc_output

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── Editor & IDE ──
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# ── Caches ──
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz

# ── Temporary Files ──
*.tmp
*.temp
.temp/

# ── User Data (local runtime, not source) ──
# The ~/Dimensions/ folder is user data, not in the repo.
# But if anyone accidentally puts scene data in the repo:
scenes/
blobs/

# ── Vercel ──
.vercel/

# ── Vite ──
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Claude Code ──
# Auto-generated scene context files (runtime only)
CLAUDE.md

# ── Misc ──
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json